{
  "name": "paintcannon",
  "version": "0.0.7",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synthetic-lab/paintcannon.git",
    "directory": "paintcannon"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "type": "module",
  "imports": {
    "#paintcannon-native": {
      "types": "./dist/napi/index.d.ts",
      "default": "./dist/napi/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist/main.js",
    "dist/main.d.ts",
    "dist/napi/index.js",
    "dist/napi/index.d.ts"
  ],
  "scripts": {
    "build": "npm run build:native:local && npm run build:ts",
    "build:debug": "npm run build:native:debug && npm run build:ts",
    "build:ts": "tsc",
    "build:native": "napi build --platform --release --output-dir dist/napi --dts index.d.ts --js index.js --esm",
    "build:native:local": "napi build --platform --release --target x86_64-unknown-linux-gnu --output-dir dist/napi --dts index.d.ts --js index.js --esm",
    "build:native:debug": "napi build --platform --target x86_64-unknown-linux-gnu --output-dir dist/napi --dts index.d.ts --js index.js --esm",
    "artifacts": "napi artifacts",
    "create-npm-dirs": "napi create-npm-dirs",
    "napi:prepublish": "napi prepublish -t npm",
    "demo": "npm run build:debug && node dist/examples/basic.js",
    "demo:alt-restart": "npm run build:debug && node dist/examples/alt-screen-restart.js",
    "demo:borders": "npm run build:debug && node dist/examples/borders.js",
    "demo:counter": "npm run build:debug && node dist/examples/counter-button.js",
    "demo:controlled": "npm run build:debug && node dist/examples/pseudo-controlled-input.js",
    "demo:chunky-rounded": "npm run build:debug && node dist/examples/chunky-rounded-hover.js",
    "demo:destroy": "npm run build:debug && node dist/examples/destroy-nodes.js",
    "demo:detach": "npm run build:debug && node dist/examples/detach-reattach.js",
    "demo:focus": "npm run build:debug && node dist/examples/focus-blur.js",
    "demo:keyboard": "npm run build:debug && node dist/examples/keyboard-events.js",
    "demo:images": "npm run build:debug && node dist/examples/images.js",
    "demo:input": "npm run build:debug && node dist/examples/input.js",
    "demo:image-scroll": "npm run build:debug && node dist/examples/image-scroll.js",
    "demo:less": "npm run build:debug && node dist/examples/less.js",
    "demo:mouse": "npm run build:debug && node dist/examples/mouse-clicks.js",
    "demo:padding": "npm run build:debug && node dist/examples/padding.js",
    "demo:margin": "npm run build:debug && node dist/examples/margin.js",
    "demo:overflow": "npm run build:debug && node dist/examples/overflow.js",
    "demo:pong": "npm run build:debug && node dist/examples/pong.js",
    "demo:scroll": "npm run build:debug && node dist/examples/scroll.js",
    "demo:scroll-percent": "npm run build:debug && node dist/examples/scroll-percent.js",
    "demo:scroll-percent-static": "npm run build:debug && node dist/examples/scroll-percent-static.js",
    "demo:span-flex": "npm run build:debug && node dist/examples/span-flex.js",
    "demo:spans": "npm run build:debug && node dist/examples/spans.js",
    "demo:textarea": "npm run build:debug && node dist/examples/textarea.js",
    "demo:transitions": "npm run build:debug && node dist/examples/transitions.js",
    "test": "npm run build:native:debug && vitest run",
    "prepublishOnly": "npm run build:native:local && npm run build:ts && node scripts/verify-native-artifacts.mjs && npm run napi:prepublish"
  },
  "napi": {
    "binaryName": "paintcannon",
    "packageName": "@syntheticlab/paintcannon-native",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "antipattern": "^0.0.7"
  }
}
