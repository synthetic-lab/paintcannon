{
  "compilerOptions": {
    "declaration": true,
    "lib": ["ES2022"],
    "allowImportingTsExtensions": true,
    "module": "NodeNext",
    "newLine": "lf",
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "outDir": "dist",
    "strict": true,
    "target": "ES2022",
    "rewriteRelativeImportExtensions": true,
    "types": ["node"]
  },
  "include": ["main.ts", "examples/**/*.ts"]
}
