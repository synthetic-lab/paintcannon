{
  "name": "paintcannon-monorepo",
  "private": true,
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synthetic-lab/paintcannon.git"
  },
  "workspaces": [
    "paintcannon",
    "paintcannon-react",
    "scripts/release"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:debug": "npm run build:debug --workspace paintcannon && npm run build --workspace paintcannon-react",
    "test": "npm run test --workspace paintcannon && npm run test --workspace paintcannon-react",
    "release": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/release/release.ts",
    "release:script:check": "npm run check --workspace @paintcannon/release",
    "release:check": "npm run format:check && npm run release:script:check && npm run test --workspaces && npm run build --workspaces && node scripts/native-build-matrix.mjs && npm pack --dry-run --cache /tmp/paintcannon-npm-cache --workspace paintcannon && npm pack --dry-run --cache /tmp/paintcannon-npm-cache --workspace paintcannon-react",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky && node scripts/install-husky-reference-transaction.mjs",
    "demo": "npm run demo --workspace paintcannon",
    "demo:alt-restart": "npm run demo:alt-restart --workspace paintcannon",
    "demo:borders": "npm run demo:borders --workspace paintcannon",
    "demo:counter": "npm run demo:counter --workspace paintcannon",
    "demo:controlled": "npm run demo:controlled --workspace paintcannon-react",
    "demo:controlled:core": "npm run demo:controlled --workspace paintcannon",
    "demo:chunky-rounded": "npm run demo:chunky-rounded --workspace paintcannon",
    "demo:destroy": "npm run demo:destroy --workspace paintcannon",
    "demo:detach": "npm run demo:detach --workspace paintcannon",
    "demo:keyboard": "npm run demo:keyboard --workspace paintcannon",
    "demo:images": "npm run demo:images --workspace paintcannon",
    "demo:input": "npm run demo:input --workspace paintcannon",
    "demo:image-scroll": "npm run demo:image-scroll --workspace paintcannon",
    "demo:less": "npm run demo:less --workspace paintcannon",
    "demo:mouse": "npm run demo:mouse --workspace paintcannon",
    "demo:padding": "npm run demo:padding --workspace paintcannon",
    "demo:margin": "npm run demo:margin --workspace paintcannon",
    "demo:overflow": "npm run demo:overflow --workspace paintcannon",
    "demo:pong": "npm run demo:pong --workspace paintcannon",
    "demo:native-scroll": "npm run demo:native-scroll --workspace paintcannon",
    "demo:scroll": "npm run demo:scroll --workspace paintcannon",
    "demo:scroll-percent": "npm run demo:scroll-percent --workspace paintcannon",
    "demo:scroll-percent-static": "npm run demo:scroll-percent-static --workspace paintcannon",
    "demo:span-flex": "npm run demo:span-flex --workspace paintcannon",
    "demo:spans": "npm run demo:spans --workspace paintcannon",
    "demo:textarea": "npm run demo:textarea --workspace paintcannon",
    "demo:todo": "npm run demo:todo --workspace paintcannon-react",
    "demo:transitions": "npm run demo:transitions --workspace paintcannon"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  }
}
