{
  "name": "paintcannon",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "scripts": {
    "build": "napi build --release --dts dist/native.d.ts && tsc",
    "build:debug": "napi build --dts dist/native.d.ts && tsc",
    "demo": "npm run build:debug && node dist/examples/basic.js",
    "demo:borders": "npm run build:debug && node dist/examples/borders.js",
    "demo:counter": "npm run build:debug && node dist/examples/counter-button.js",
    "demo:chunky-rounded": "npm run build:debug && node dist/examples/chunky-rounded-hover.js",
    "demo:keyboard": "npm run build:debug && node dist/examples/keyboard-events.js",
    "demo:images": "npm run build:debug && node dist/examples/images.js",
    "demo:input": "npm run build:debug && node dist/examples/input.js",
    "demo:image-scroll": "npm run build:debug && node dist/examples/image-scroll.js",
    "demo:less": "npm run build:debug && node dist/examples/less.js",
    "demo:mouse": "npm run build:debug && node dist/examples/mouse-clicks.js",
    "demo:overflow": "npm run build:debug && node dist/examples/overflow.js",
    "demo:pong": "npm run build:debug && node dist/examples/pong.js",
    "demo:scroll": "npm run build:debug && node dist/examples/scroll.js",
    "demo:scroll-percent": "npm run build:debug && node dist/examples/scroll-percent.js",
    "demo:scroll-percent-static": "npm run build:debug && node dist/examples/scroll-percent-static.js",
    "demo:spans": "npm run build:debug && node dist/examples/spans.js",
    "demo:textarea": "npm run build:debug && node dist/examples/textarea.js",
    "demo:transitions": "npm run build:debug && node dist/examples/transitions.js",
    "probe:tmux-pointer": "npm run build:debug && node dist/examples/tmux-pointer-probe.js"
  },
  "napi": {
    "binaryName": "paintcannon",
    "targets": []
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
