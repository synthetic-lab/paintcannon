{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "newLine": "lf",
    "noEmit": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["release.ts"]
}
