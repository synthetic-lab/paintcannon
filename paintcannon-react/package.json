{
  "name": "paintcannon-react",
  "version": "0.0.5",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synthetic-lab/paintcannon.git",
    "directory": "paintcannon-react"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "files": [
    "README.md",
    "LICENSE",
    "dist/src"
  ],
  "scripts": {
    "build": "tsc",
    "demo": "npm run build && node dist/examples/counter.js",
    "demo:controlled": "npm run build && node dist/examples/controlled.js",
    "demo:form": "npm run build && node dist/examples/form.js",
    "demo:keyboard": "npm run build && node dist/examples/keyboard.js",
    "demo:lifecycle": "npm run build && node dist/examples/lifecycle.js",
    "demo:spinner": "npm run build && node dist/examples/spinner.js",
    "demo:todo": "npm run build && node dist/examples/todo.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "react-reconciler": "^0.31.0",
    "scheduler": "^0.25.0"
  },
  "peerDependencies": {
    "paintcannon": "^0.0.4",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.0.0",
    "@types/react-reconciler": "^0.33.0",
    "@types/scheduler": "^0.26.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
