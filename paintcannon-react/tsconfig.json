{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2022"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "newLine": "lf",
    "noImplicitOverride": true,
    "outDir": "dist",
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "examples/**/*.tsx"]
}
